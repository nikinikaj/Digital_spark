# Real deployment configuration for the agency pipeline

# SMTP settings for sending real outreach emails.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password
EMAIL_FROM=agency@example.com
ADMIN_EMAIL=your_admin_email@example.com

# PayPal setup for generating invoice links. Replace with your own PayPal.Me username.
PAYPAL_BASE_URL=https://www.paypal.com/paypalme/YourBusiness

# Optional: choose a niche for the first campaign
#NICHES=all
